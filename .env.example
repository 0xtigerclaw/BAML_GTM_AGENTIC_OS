NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Set true on Vercel/hosted demos so reviewers can approve opportunities
# and receive completed BAML packages without your local OpenClaw Gateway.
NEXT_PUBLIC_HOSTED_DEMO=true

# Local-only real gateway mode can use ChatGPT auth through clawdbot.
LLM_PROVIDER=clawdbot
